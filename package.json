{
  "name": "grid-video-player",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop multi-video grid player built with Electron, React, Tailwind, and Zustand.",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:web": "vite",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.electron.json -w",
    "dev:electron": "wait-on tcp:5173 file:dist-electron/electron/main.js && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:web": "vite build",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "preview:web": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:headed": "npm run build && playwright test --headed",
    "test:e2e:debug": "npm run build && playwright test --debug"
  },
  "dependencies": {
    "dashjs": "^4.7.4",
    "electron-store": "^10.0.1",
    "hls.js": "^1.5.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.10",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@playwright/test": "^1.54.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "electron": "^31.0.2",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^2.0.5",
    "wait-on": "^8.0.1",
    "jsdom": "^25.0.1"
  }
}
